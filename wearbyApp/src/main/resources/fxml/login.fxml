<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<BorderPane xmlns:fx = "http://javafx.com/fxml"
            fx:controller="com.wearby.controlador.LoginControlador"
            prefHeight="800" prefWidth="1200"
            style="-fx-background-color: #f5f5f5">
    <center>
        <VBox alignment="CENTER" spacing="20"
              maxWidth="400" maxHeight="500"
              styleClass="tarjeta">

            <padding>
                <Insets top="40" right="40" bottom="40" left="40" />
            </padding>

            <!-- Título -->
            <Label text="Wearby" styleClass="titulo" />
            <Label text="Inicia sesión en tu cuenta" styleClass="subtitulo" />

            <!-- Campos -->
            <VBox spacing="8">
                <Label text="Email" />
                <TextField fx:id="emailField"
                           promptText="tu@email.com"
                           styleClass="campo-texto"
                           prefWidth="320" />
            </VBox>

            <VBox spacing="8">
                <Label text="Contraseña" />
                <PasswordField fx:id="contrasenaField"
                               promptText="Contraseña"
                               styleClass="campo-texto"
                               prefWidth="320" />
            </VBox>

            <!-- Mensaje de error -->
            <Label fx:id="errorLabel"
                text=""
                style="-fx-text-fill: #e74c3c; -fx-font-size: 13px"/>

            <!-- Botón login -->
            <Button fx:id="loginBtn"
                    text="Iniciar sesión"
                    style="btn-primary"
                    prefWidth="320"
                    onAction="#onLogin" />

            <Separator />

            <!-- Ir a registro -->
            <HBox alignment="CENTER" spacing="8">
                <Label text="¿No tienes cuenta?" />
                <Button text="Regístrate"
                        style="-fx-background-color: transparent; -fx-text-fill: #2c2c2c; -fx-underline: true; -fx-cursor: hand"
                        onAction="#onIrARegistro" />
            </HBox>
        </VBox>
    </center>
</BorderPane>