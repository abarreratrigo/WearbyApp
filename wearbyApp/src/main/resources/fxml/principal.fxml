<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.wearby.controlador.PrincipalControlador"
            prefHeight="800" prefWidth="1200"
            stylesheets="@../css/estilos.css">

    <!-- Barra lateral izquierda -->
    <left>
        <VBox prefWidth="230"
              style="-fx-background-color: #102e4e;">

            <!-- Logo / nombre -->
            <VBox alignment="CENTER" prefHeight="110"
                  style="-fx-background-color: #1f5182; -fx-spacing: 8;">
                <padding>
                    <Insets top="20" bottom="20" />
                </padding>

                <StackPane prefWidth="72" prefHeight="90"
                           maxWidth="72" maxHeight="72"
                           style="-fx-background-color: #f9f9f9;
                      -fx-background-radius: 36;"
                           alignment="CENTER">
                    <ImageView fitWidth="64" fitHeight="90" preserveRatio="true">
                        <image>
                            <Image url="@../img/logo.png" />
                        </image>
                    </ImageView>
                </StackPane>

                <Label text="Wearby"
                       style="-fx-text-fill: #f9f9f9;
                  -fx-font-size: 18px;
                  -fx-font-weight: bold;" />
            </VBox>

            <!-- Nombre del usuario -->
            <VBox alignment="CENTER" prefHeight="48"
                  style="-fx-background-color: #102e4e;">
                <Label fx:id="nombreUsuarioLabel"
                       text=""
                       style="-fx-text-fill: #bed4d2;
                              -fx-font-size: 12px;
                              -fx-font-style: italic;" />
            </VBox>

            <!-- Separador decorativo -->
            <Region prefHeight="1"
                    style="-fx-background-color: #1f5182;"
                    prefWidth="230" />

            <!-- Botones de navegación -->
            <VBox style="-fx-spacing: 2; -fx-padding: 8 0 8 0;">

                <Button fx:id="btnArmario"
                        text=" Mi armario"
                        styleClass="nav-boton-activo"
                        prefWidth="230"
                        onAction="#onArmario" />

                <Button fx:id="btnFavoritos"
                        text=" Favoritos"
                        styleClass="nav-boton"
                        prefWidth="230"
                        onAction="#onFavoritos" />

                <Button fx:id="btnOutfits"
                        text=" Generar outfits"
                        styleClass="nav-boton"
                        prefWidth="230"
                        onAction="#onOutfits" />

                <Button fx:id="btnPerfil"
                        text=" Mi perfil"
                        styleClass="nav-boton"
                        prefWidth="230"
                        onAction="#onPerfil" />
            </VBox>

            <!-- Espaciador -->
            <Region VBox.vgrow="ALWAYS" />

            <!-- Separador inferior -->
            <Region prefHeight="1"
                    style="-fx-background-color: #1f5182;"
                    prefWidth="230" />

            <!-- Cerrar sesión -->
            <Button text="⏻ Cerrar sesión"
                    styleClass="nav-boton"
                    prefWidth="230"
                    style="-fx-text-fill: #bed4d2;
                           -fx-font-size: 13px;"
                    onAction="#onCerrarSesion" />

        </VBox>
    </left>

    <!-- Área de contenido central -->
    <center>
        <StackPane fx:id="contenidoCentral"
                   style="-fx-background-color: #bed4d2;">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30" />
            </padding>
        </StackPane>
    </center>

</BorderPane>