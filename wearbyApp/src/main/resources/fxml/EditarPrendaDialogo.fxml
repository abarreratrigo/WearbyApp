<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wearby.controlador.EditarPrendaControlador"
      spacing="16" prefWidth="420"
      style="-fx-background-color: white; -fx-padding: 24;">

    <Label text="Editar prenda"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1f5182;"/>

    <Label text="Nombre *"
           style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
    <TextField fx:id="nombreField" promptText="Nombre de la prenda"
               style="-fx-border-color: #bed4d2; -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 8;"/>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Categoría *" style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
            <ComboBox fx:id="categoriaCombo" maxWidth="Infinity"
                      style="-fx-border-color: #bed4d2; -fx-border-radius: 6;"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Color" style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
            <ComboBox fx:id="colorCombo" maxWidth="Infinity"
                      style="-fx-border-color: #bed4d2; -fx-border-radius: 6;"/>
        </VBox>
    </HBox>

    <HBox spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Estilo" style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
            <ComboBox fx:id="estiloCombo" maxWidth="Infinity"
                      style="-fx-border-color: #bed4d2; -fx-border-radius: 6;"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Formalidad" style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
            <ComboBox fx:id="formalidadCombo" maxWidth="Infinity"
                      style="-fx-border-color: #bed4d2; -fx-border-radius: 6;"/>
        </VBox>
    </HBox>

    <VBox spacing="4">
        <Label text="Temporada" style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
        <ComboBox fx:id="temporadaCombo" maxWidth="Infinity"
                  style="-fx-border-color: #bed4d2; -fx-border-radius: 6;"/>
    </VBox>

    <CheckBox fx:id="favoritoCheck" text="Marcar como favorita"
              style="-fx-text-fill: #333;"/>

    <VBox spacing="4">
        <Label text="Notas" style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
        <TextArea fx:id="notasArea" promptText="Notas opcionales..."
                  prefRowCount="3" wrapText="true"
                  style="-fx-border-color: #bed4d2; -fx-border-radius: 6; -fx-background-radius: 6;"/>
    </VBox>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar" text="Cancelar"
                onAction="#onCancelar"
                style="-fx-background-color: #f5f5f5; -fx-text-fill: #555;
                       -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
        <Button fx:id="btnGuardar" text="Guardar cambios"
                onAction="#onGuardar"
                style="-fx-background-color: #1f5182; -fx-text-fill: white;
                       -fx-border-radius: 6; -fx-background-radius: 6;
                       -fx-padding: 8 20 8 20; -fx-cursor: hand;
                       -fx-font-weight: bold;"/>
    </HBox>
</VBox>