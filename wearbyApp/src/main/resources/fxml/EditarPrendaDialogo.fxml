<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wearby.controlador.EditarPrendaControlador"
      stylesheets="@../css/estilos.css"
      spacing="16"
      prefWidth="500"
      style="-fx-background-color: #f9f9f9; -fx-padding: 30;">

    <!-- Título -->
    <Label text="Editar prenda" styleClass="titulo" />

    <!-- Nombre -->
    <VBox spacing="6">
        <Label text="Nombre" styleClass="label-campo" />
        <TextField fx:id="nombreField"
                   promptText="Ej: Camiseta Blanca"
                   styleClass="campo-texto"
                   prefWidth="440" />
    </VBox>

    <!-- Fila: Categoría + Color -->
    <HBox spacing="12">
        <VBox spacing="6">
            <Label text="Categoría" styleClass="label-campo" />
            <ComboBox fx:id="categoriaCombo"
                      prefWidth="210"
                      styleClass="campo-texto" />
        </VBox>
        <VBox spacing="6">
            <Label text="Color" styleClass="label-campo" />
            <ComboBox fx:id="colorCombo"
                      prefWidth="210"
                      styleClass="campo-texto" />
        </VBox>
    </HBox>

    <!-- Fila: Estilo + Formalidad -->
    <HBox spacing="12">
        <VBox spacing="6">
            <Label text="Estilo" styleClass="label-campo" />
            <ComboBox fx:id="estiloCombo"
                      prefWidth="210"
                      styleClass="campo-texto" />
        </VBox>
        <VBox spacing="6">
            <Label text="Formalidad" styleClass="label-campo" />
            <ComboBox fx:id="formalidadCombo"
                      prefWidth="210"
                      styleClass="campo-texto" />
        </VBox>
    </HBox>

    <!-- Temporada -->
    <VBox spacing="6">
        <Label text="Temporada" styleClass="label-campo" />
        <ComboBox fx:id="temporadaCombo"
                  prefWidth="210"
                  styleClass="campo-texto" />
    </VBox>

    <!-- Favorito -->
    <CheckBox fx:id="favoritoCheck"
              text="Marcar como favorita"
              style="-fx-text-fill: #102e4e; -fx-font-size: 13px;" />

    <!-- Notas -->
    <VBox spacing="6">
        <Label text="Notas (opcional)" styleClass="label-campo" />
        <TextArea fx:id="notasArea"
                  promptText="Añade notas sobre esta prenda..."
                  prefHeight="80"
                  prefWidth="440"
                  styleClass="campo-texto"
                  wrapText="true" />
    </VBox>

    <!-- Botones acción -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancelar"
                style="-fx-background-color: #bed4d2;
                       -fx-text-fill: #102e4e;
                       -fx-font-size: 14px;
                       -fx-padding: 10 20 10 20;
                       -fx-background-radius: 6;
                       -fx-border-radius: 6;
                       -fx-cursor: hand;"
                onAction="#onCancelar" />
        <Button fx:id="btnGuardar"
                text="Guardar cambios"
                styleClass="btn-primary"
                onAction="#onGuardar" />
    </HBox>

</VBox>