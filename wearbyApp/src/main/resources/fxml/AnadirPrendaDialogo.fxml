<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.wearby.controlador.AnadirPrendaControlador"
      stylesheets="@../css/estilos.css"
      spacing="16"
      prefWidth="500"
      style="-fx-background-color: #f9f9f9; -fx-padding: 30;">

    <!-- Título -->
    <Label text="Añadir prenda" styleClass="titulo" />

    <!-- Preview imagen + botón seleccionar -->
    <HBox spacing="16" alignment="CENTER_LEFT">

        <StackPane prefWidth="120" prefHeight="120"
                   style="-fx-background-color: #bed4d2;
                          -fx-background-radius: 10;
                          -fx-border-color: #bed4d2;
                          -fx-border-radius: 10;
                          -fx-border-width: 1;">
            <ImageView fx:id="imagenPreview"
                       fitHeight="112" fitWidth="112"
                       preserveRatio="true" />
        </StackPane>

        <VBox spacing="8" alignment="CENTER_LEFT">
            <Button text="Seleccionar imagen"
                    styleClass="btn-primary"
                    onAction="#onSeleccionarImagen" />
            <Label text="JPG o PNG recomendado"
                   styleClass="label-muted" />
        </VBox>

    </HBox>

    <!-- Nombre -->
    <VBox spacing="6">
        <Label text="Nombre" styleClass="label-campo" />
        <TextField fx:id="nombreField"
                   promptText="Ej: Camiseta Blanca"
                   styleClass="campo-texto"
                   prefWidth="440" />
    </VBox>

    <!-- Fila: Categoría + Color -->
    <HBox spacing="12">
        <VBox spacing="6">
            <Label text="Categoría" styleClass="label-campo" />
            <ComboBox fx:id="categoriaCombo"
                      prefWidth="210"
                      styleClass="campo-texto" />
        </VBox>
        <VBox spacing="6">
            <Label text="Color" styleClass="label-campo" />
            <ComboBox fx:id="colorCombo"
                      prefWidth="210"
                      styleClass="campo-texto" />
        </VBox>
    </HBox>

    <!-- Fila: Estilo + Formalidad -->
    <HBox spacing="12">
        <VBox spacing="6">
            <Label text="Estilo" styleClass="label-campo" />
            <ComboBox fx:id="estiloCombo"
                      prefWidth="210"
                      styleClass="campo-texto" />
        </VBox>
        <VBox spacing="6">
            <Label text="Formalidad" styleClass="label-campo" />
            <ComboBox fx:id="formalidadCombo"
                      prefWidth="210"
                      styleClass="campo-texto" />
        </VBox>
    </HBox>

    <!-- Temporada -->
    <VBox spacing="6">
        <Label text="Temporada" styleClass="label-campo" />
        <ComboBox fx:id="temporadaCombo"
                  prefWidth="210"
                  styleClass="campo-texto" />
    </VBox>

    <!-- Notas -->
    <VBox spacing="6">
        <Label text="Notas (opcional)" styleClass="label-campo" />
        <TextArea fx:id="notasArea"
                  promptText="Añade notas sobre esta prenda..."
                  prefHeight="80"
                  prefWidth="440"
                  styleClass="campo-texto"
                  wrapText="true" />
    </VBox>

    <!-- Error -->
    <Label fx:id="errorLabel"
           text=""
           styleClass="label-error" />

    <!-- Botones acción -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancelar"
                style="-fx-background-color: #bed4d2;
               -fx-text-fill: #102e4e;
               -fx-font-size: 14px;
               -fx-padding: 10 20 10 20;
               -fx-background-radius: 6;
               -fx-border-radius: 6;
               -fx-cursor: hand;"
                onAction="#onCancelar" />
        <Button fx:id="guardarBtn"
                text="Guardar prenda"
                styleClass="btn-primary"
                onAction="#onGuardar" />
    </HBox>

</VBox>