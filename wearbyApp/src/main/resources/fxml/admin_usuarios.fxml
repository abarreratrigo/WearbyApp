<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.wearby.controlador.AdminUsuariosControlador"
      spacing="16">

    <Label text="Gestión de usuarios"
           style="-fx-font-size: 20px; -fx-font-weight: bold;" />

    <TableView fx:id="tablaUsuarios" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="180"/>
            <TableColumn fx:id="colEmail" text="Email" prefWidth="220"/>
            <TableColumn fx:id="colRol" text="Rol" prefWidth="100"/>
            <TableColumn fx:id="colActivo" text="Estado" prefWidth="100"/>
            <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="200"/>
        </columns>
    </TableView>
</VBox>